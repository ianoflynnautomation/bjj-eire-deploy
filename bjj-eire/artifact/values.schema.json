{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "bjj-eire umbrella values",
  "type": "object",
  "required": ["bjj-mongodb", "bjj-api", "bjj-frontend", "seeder"],
  "properties": {
    "bjj-mongodb": {
      "type": "object",
      "required": ["namespace", "mongodb"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "mongodb": {
          "type": "object",
          "required": ["enabled", "image", "resources", "persistence"],
          "properties": {
            "enabled": { "type": "boolean" },
            "replicaCount": { "type": "integer", "minimum": 1 },
            "image": { "$ref": "#/definitions/image" },
            "resources": { "$ref": "#/definitions/resources" },
            "persistence": {
              "type": "object",
              "required": ["enabled", "size"],
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" },
                "storageClassName": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "bjj-api": {
      "type": "object",
      "required": ["namespace", "api"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "api": {
          "type": "object",
          "required": ["enabled", "image", "service", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "replicaCount": { "type": "integer", "minimum": 1 },
            "image": { "$ref": "#/definitions/image" },
            "service": { "$ref": "#/definitions/service" },
            "resources": { "$ref": "#/definitions/resources" },
            "autoscaling": { "$ref": "#/definitions/autoscaling" },
            "podDisruptionBudget": { "$ref": "#/definitions/pdb" }
          }
        }
      }
    },
    "bjj-frontend": {
      "type": "object",
      "required": ["namespace", "frontend"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "frontend": {
          "type": "object",
          "required": ["enabled", "image", "service", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "replicaCount": { "type": "integer", "minimum": 1 },
            "image": { "$ref": "#/definitions/image" },
            "service": { "$ref": "#/definitions/service" },
            "resources": { "$ref": "#/definitions/resources" },
            "autoscaling": { "$ref": "#/definitions/autoscaling" },
            "podDisruptionBudget": { "$ref": "#/definitions/pdb" }
          }
        }
      }
    },
    "seeder": {
      "type": "object",
      "required": ["enabled", "image"],
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": {
              "type": "string",
              "minLength": 1,
              "not": { "const": "latest" },
              "description": "Pinned tag required — never 'latest' in production"
            },
            "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": {
          "type": "string",
          "not": { "const": "latest" },
          "description": "Image tag. Empty allowed — Flux ImageUpdateAutomation sets this via HelmRelease."
        },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "httpsPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    }
  }
}
